/**
 * Global styles. Intentionally minimal - this is NOT a full design system.
 * Only a handful of shared tokens and layout helpers for the shell.
 */
page {
  --color-primary: #2b5c8f;
  --color-bg: #f5f6f8;
  --color-card: #ffffff;
  --color-text: #1f2329;
  --color-text-weak: #8a9099;
  background-color: var(--color-bg);
  color: var(--color-text);
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: var(--color-card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.title {
  font-size: 34rpx;
  font-weight: 600;
}

.text-weak {
  color: var(--color-text-weak);
}

.btn-primary {
  background: var(--color-primary);
  color: #fff;
  border-radius: 12rpx;
}
