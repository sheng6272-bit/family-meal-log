.totals {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
}
.metric {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.num {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-primary);
}
.meal-slots {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
}
.add-btn {
  margin-top: 24rpx;
}
.manage-btn {
  margin-top: 16rpx;
}
.card-tap {
  /* tap affordance for the active-profile card */
}
.btn-ghost {
  background: #ffffff;
  color: var(--color-primary);
  border: 1rpx solid var(--color-primary);
}
