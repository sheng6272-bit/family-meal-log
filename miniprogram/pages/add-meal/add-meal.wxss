.slots {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}
.slot {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  background: #eef1f5;
  color: var(--color-text-weak);
}
.slot-active {
  background: var(--color-primary);
  color: #fff;
}
.item-btn,
.save-btn {
  margin-top: 24rpx;
}
