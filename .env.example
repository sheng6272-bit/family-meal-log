# =====================================================================
# Family Meal Log MVP - Environment configuration TEMPLATE
# ---------------------------------------------------------------------
# Copy this file to `.env` (which is git-ignored) and fill in real values.
# NEVER commit a real .env. NEVER put these values directly in client code.
#
# In a WeChat Mini Program the client cannot read process.env at runtime.
# The values below are consumed in two places:
#   1. Build / tooling scripts (Node).
#   2. Injected into `miniprogram/config/env.local.ts` (git-ignored) by a
#      developer, OR referenced by cloud-function environment variables.
# Cloud-function secrets (AI keys) live ONLY in the CloudBase console /
# function environment variables, never in this repo.
# =====================================================================

# ---- CloudBase environments (IDs are non-secret but environment-specific) ----
# Keep them out of committed client code; inject at build/config time.
CLOUDBASE_ENV_DEV=your-dev-env-id
CLOUDBASE_ENV_PROD=your-prod-env-id

# Which environment the local build targets: "dev" | "prod"
APP_ENV=dev

# ---- AI provider (server-side ONLY; used by cloud functions) ----
# Leave AI_PROVIDER=mock until a real provider is integrated.
# When set to a real provider, configure the secret in the CloudBase
# function environment variables, NOT here in the repo.
AI_PROVIDER=mock
# AI_API_BASE_URL=
# AI_API_KEY=            # <-- set in CloudBase console only, never commit
# AI_MODEL=
