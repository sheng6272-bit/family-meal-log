{
  "name": "family-meal-log",
  "version": "0.1.0",
  "private": true,
  "description": "Family Meal Log MVP - a family-oriented food-intake logging WeChat Mini Program built on Tencent CloudBase.",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:shared": "node scripts/build-shared.mjs",
    "test": "npm run build:shared && node scripts/validate.mjs",
    "validate": "npm run typecheck && npm run test",
    "clean": "node -e \"require('fs').rmSync('shared/dist',{recursive:true,force:true});require('fs').rmSync('cloudfunctions/login/lib/shared',{recursive:true,force:true});require('fs').rmSync('cloudfunctions/profileApi/lib/shared',{recursive:true,force:true});require('fs').rmSync('cloudfunctions/mealApi/lib/shared',{recursive:true,force:true});require('fs').rmSync('cloudfunctions/aiAnalyze/lib/shared',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "miniprogram-api-typings": "^3.12.0",
    "typescript": "^5.4.0"
  }
}
