# ---- Dependencies ----
node_modules/
**/node_modules/

# ---- Build output ----
dist/
shared/dist/
miniprogram/**/*.js
miniprogram/**/*.js.map
!miniprogram/**/*.config.js
# Cloud-function SOURCE (.js) is committed; only the GENERATED shared runtime
# copied into each function at build time is ignored.
cloudfunctions/*/lib/shared/
cloudfunctions/*/node_modules/
cloudfunctions/**/*.js.map
*.tsbuildinfo

# ---- Secrets & local environment ----
# Never commit real credentials, environment IDs or API keys.
.env
.env.*
!.env.example
config/*.local.*
project.private.config.json

# ---- WeChat DevTools ----
project.private.config.json
.wechatide/

# ---- Logs & OS files ----
*.log
npm-debug.log*
.DS_Store
Thumbs.db

# ---- WorkBuddy project memory (never commit) ----
.workbuddy/

# ---- Editor ----
.idea/
.vscode/*
!.vscode/extensions.json

miniprogram/config/env.local.ts

.env
